const tg = window.Telegram.WebApp;
tg.expand(); // App ko full screen karne ke liye

// Coins Initialization
let coins = parseInt(localStorage.getItem('user_coins')) || 0;
const balanceEl = document.getElementById('balance');
if(balanceEl) balanceEl.innerText = coins + " 🪙";

function switchTab(tabId, el) {
    // 1. Saare tabs ko hide karo (Logic: display = 'none')
    const tabs = document.querySelectorAll('.tab-content');
    tabs.forEach(tab => {
        tab.style.display = 'none'; // Ye sabse zaroori line hai
        tab.classList.remove('active-tab');
    });

    // 2. Saare buttons se active class hatao
    const buttons = document.querySelectorAll('.nav-item');
    buttons.forEach(btn => btn.classList.remove('active'));

    // 3. Target tab ko dhoondo aur dikhao
    const target = document.getElementById(tabId);
    if (target) {
        target.style.display = 'block'; // Forcefully show
        target.classList.add('active-tab');
        el.classList.add('active');
        
        // Header title update
        const titleHeader = document.getElementById('tab-title');
        if(titleHeader) titleHeader.innerText = tabId.charAt(0).toUpperCase() + tabId.slice(1);
    } else {
        console.error("Bhai, id='" + tabId + "' nahi mili HTML mein!");
    }
}

function claimDaily() {
    coins += 10;
    localStorage.setItem('user_coins', coins);
    if(balanceEl) balanceEl.innerText = coins + " 🪙";
    tg.showAlert("Congrats! 10 Coins added. 🎁");
}

function sendSupport() {
    const msgEl = document.getElementById('support-msg');
    const msg = msgEl ? msgEl.value : "";
    
    if(!msg.trim()) {
        tg.showAlert("Kuch toh likho bhai!");
        return;
    }
    
    // Python bot ko data bhejna
    tg.sendData(JSON.stringify({type: "support", message: msg}));
    tg.showAlert("Message sent to Admin! ✅");
    if(msgEl) msgEl.value = "";
}
